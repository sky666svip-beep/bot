# ===================== 通用 Python 忽略规则 =====================
# 忽略所有位置的 __pycache__ 目录（核心：一行覆盖所有）
__pycache__/
# 忽略 Python 编译文件
*.py[cod]
*$py.class
# ===================== 项目目录忽略 =====================
# 缓存/实例目录
model_cache_*/
instance/
/llama-cuda
/Qwen3-Reranker-0.6B
1.html
Biology.html
Chemistry.html
Geography.html
function.html
Major_historical_events.html
# IDE/编辑器配置
.idea/
.vscode/
# 自定义缓存/配置
.agent/
.lingma/
# 数据目录（任意位置的 data 文件夹）
**/data/
# 日志目录
logs/
test/
task_plan.md
findings.md
# ===================== 部署相关 =====================
cloudflared.exe
config.yml
start_*.bat
register_autostart.bat
stop_all.bat
.venv/
# 配置文件/敏感信息
*.json
.env
# 1. 查看本地修改状态git status
# 2. 将所有修改的文件添加到暂存区（. 表示所有，也可指定文件如 git add index.html）git add .
# 3. 提交暂存区文件到本地仓库，-m 后加提交说明（必须写，简洁描述修改内容）git commit -m ""
# 4. 拉取远程仓库最新代码（避免冲突，建议每次推送前先拉取）git pull origin 分支名（如 main 或 master）
# 5. 推送本地提交到 GitHub 远程仓库git push origin main 分支名（如 main 或 master）